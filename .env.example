# === Required ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_AUTHORIZED_USER_ID=your-telegram-numeric-user-id

# === LLM API Keys ===
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# === Optional Security ===
# Set a PIN that must be entered after bot restart before it accepts commands
# Leave blank to disable
SESSION_PIN=

# Max outbound actions (emails, messages) per hour
RATE_LIMIT_PER_HOUR=20

# === Gmail (added after OAuth setup) ===
# GMAIL_CREDENTIALS_PATH=credentials.json
# GMAIL_TOKEN_PATH=token.json

# === Pushover Notifications ===
# PUSHOVER_USER_KEY=your-pushover-user-key
# PUSHOVER_APP_TOKEN=your-pushover-app-token

# === OneDrive (personal Microsoft account) ===
# ONEDRIVE_CLIENT_ID=your-azure-app-client-id
# INDEX_POLL_INTERVAL_MINUTES=10

# === Google Places API (for review monitoring) ===
# GOOGLE_PLACES_API_KEY=your-google-places-api-key
# REVIEW_POLL_INTERVAL_MINUTES=15
